GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models

APP_CORS_ALLOWED_ORIGINS=http://writeloop.localtest.me
APP_FRONTEND_BASE_URL=http://writeloop.localtest.me
NEXT_PUBLIC_API_BASE_URL=http://api.localtest.me
APP_AUTH_REMEMBER_ME_DAYS=30
APP_ADMIN_EMAILS=admin@example.com
NGINX_CONF_PATH=infra/nginx/dev.conf

SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/writeloop?useSSL=false&allowPublicKeyRetrieval=true&connectionTimeZone=Asia/Seoul&forceConnectionTimeZoneToSession=true
SPRING_DATASOURCE_USERNAME=writeloop_user
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_DATA_REDIS_HOST=writeloop-redis
SPRING_DATA_REDIS_PORT=6379
APP_DRAFT_TTL_DAYS=7

SPRING_MAIL_HOST=smtp.naver.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=yourid@naver.com
SPRING_MAIL_PASSWORD=your-password
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
APP_MAIL_FROM=yourid@naver.com

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_AUTHORIZATION_URI=https://nid.naver.com/oauth2.0/authorize
NAVER_TOKEN_URI=https://nid.naver.com/oauth2.0/token
NAVER_USER_INFO_URI=https://openapi.naver.com/v1/nid/me
NAVER_REDIRECT_URI=http://api.localtest.me/api/auth/social/naver/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTHORIZATION_URI=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_USER_INFO_URI=https://openidconnect.googleapis.com/v1/userinfo
GOOGLE_REDIRECT_URI=http://api.localtest.me/api/auth/social/google/callback

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_AUTHORIZATION_URI=https://kauth.kakao.com/oauth/authorize
KAKAO_TOKEN_URI=https://kauth.kakao.com/oauth/token
KAKAO_USER_INFO_URI=https://kapi.kakao.com/v2/user/me
KAKAO_REDIRECT_URI=http://api.localtest.me/api/auth/social/kakao/callback
