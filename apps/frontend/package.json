{
  "name": "@english-learning/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cap:copy": "npx cap copy",
    "cap:sync": "npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "build:mobile:web": "cross-env BUILD_TARGET=capacitor next build",
    "mobile:build": "npm run build:mobile:web && npx cap sync",
    "mobile:build:android:dev": "cross-env BUILD_TARGET=capacitor NEXT_PUBLIC_API_BASE_URL=http://10.0.2.2 next build && npx cap sync android",
    "mobile:run:android:dev": "npm run mobile:build:android:dev && cd android && gradlew.bat installDebug"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.3",
    "canvas-confetti": "^1.9.4",
    "motion": "^12.38.0",
    "next": "15.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.11.30",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.4",
    "cross-env": "^10.0.0",
    "eslint": "^9.24.0",
    "eslint-config-next": "15.2.0",
    "typescript": "^5.4.5"
  }
}
