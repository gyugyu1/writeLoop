{
  "name": "english-learning-app",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo starter for an English learning app (next.js frontend + spring boot backend).",
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace @english-learning/frontend",
    "build:frontend": "npm run build --workspace @english-learning/frontend",
    "lint:frontend": "npm run lint --workspace @english-learning/frontend",
    "mobile:build": "npm run mobile:build --workspace @english-learning/frontend",
    "mobile:android:add": "npm run cap:add:android --workspace @english-learning/frontend",
    "mobile:android:open": "npm run cap:open:android --workspace @english-learning/frontend",
    "mobile:sync": "npm run cap:sync --workspace @english-learning/frontend",
    "mobile:android:dev": "npm run mobile:build:android:dev --workspace @english-learning/frontend",
    "mobile:android:run:dev": "npm run mobile:run:android:dev --workspace @english-learning/frontend",
    "mobile:rn:start": "npm --prefix apps/mobile run start",
    "mobile:rn:start:android-studio": "npm --prefix apps/mobile run start:android-studio",
    "mobile:rn:start:tunnel": "npm --prefix apps/mobile run start:tunnel",
    "mobile:rn:android": "npm --prefix apps/mobile run android",
    "mobile:rn:android:emulator": "npm --prefix apps/mobile run android:emulator",
    "mobile:rn:web": "npm --prefix apps/mobile run web",
    "mobile:rn:lint": "npm --prefix apps/mobile run lint",
    "mobile:rn:typecheck": "npm --prefix apps/mobile exec tsc --noEmit"
  }
}
